# YOLO / Ultralytics dataset configuration for E. coli detection.
# Copy this file to training/dataset.yaml and fill in real paths.
#
# Expected directory layout:
#   data/ecoli/
#     ├── images/
#     │   ├── train/   *.jpg or *.png
#     │   ├── val/
#     │   └── test/    (optional)
#     └── labels/
#         ├── train/   *.txt — one box per line:
#         │              <class_id> <cx> <cy> <w> <h>   (all normalized to [0, 1])
#         ├── val/
#         └── test/
#
# Converting from COCO JSON to YOLO format:
#   python -c "from ultralytics.data.converter import convert_coco; \
#              convert_coco('path/to/coco/annotations', use_segments=False, cls91to80=False)"
# The converter writes YOLO .txt labels next to the JSON; move them into
# the layout above.

path: ../data/ecoli       # Dataset root, relative to this yaml's directory
train: images/train       # Train images, relative to 'path'
val: images/val
test: images/test         # Optional; remove if unused

# Class id → name. Order matters — must match labels and config.yaml.
names:
  0: ecoli

# Optional: shell snippet Ultralytics will run if the dataset is missing.
# download: |
#   wget https://example.com/ecoli-dataset.zip
#   unzip ecoli-dataset.zip -d ../data/
