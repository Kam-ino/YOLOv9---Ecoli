# Frontend environment variables.
# Copy to .env (gitignored) or set in Vercel's project settings.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Where the FastAPI backend lives. LEAVE BLANK for local development
# (the Vite dev proxy and the single-process serve both use the same
# origin as the UI). SET to your backend's public URL when the UI is
# hosted somewhere else, e.g. on Vercel.
#
# Examples:
#   VITE_API_BASE_URL=                                  # local dev / single-process
#   VITE_API_BASE_URL=https://abc123.trycloudflare.com  # Cloudflare Tunnel
#   VITE_API_BASE_URL=https://abc-456.ngrok-free.app    # ngrok tunnel
#
# Constraint: when the UI is HTTPS (which Vercel always is), this URL
# must ALSO be HTTPS. Browsers block plain http:// from an https:// page.
VITE_API_BASE_URL=
